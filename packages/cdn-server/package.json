{
	"name": "@pebbers/cdn-server",
	"type": "module",
	"packageManager": "bun@1.3.10",
	"exports": {
		".": "./src/types/cdn.ts"
	},
	"scripts": {
		"dev": "bun run --hot src/local.ts",
		"build": "esbuild --bundle --outfile=./dist/index.js --platform=node --target=node20 ./src/lambda.ts",
		"zip": "zip -j dist/lambda.zip dist/index.js",
		"update": "aws lambda update-function-code --zip-file fileb://dist/lambda.zip --function-name pebbers-cdn",
		"deploy": "run-s build zip update"
	},
	"devDependencies": {
		"esbuild": "^0.21.4",
		"npm-run-all2": "^6.2.0"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1047.0",
		"@aws-sdk/lib-storage": "^3.1047.0",
		"@aws-sdk/s3-request-presigner": "^3.1047.0",
		"@hono/zod-validator": "^0.7.6",
		"@orpc/server": "^1.14.3",
		"hono": "^4.12.18",
		"zod": "^4.4.3"
	}
}
